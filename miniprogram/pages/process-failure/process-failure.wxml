<view class="container">
  <view class="card section hero-card">
    <view class="hero-icon">!</view>
    <view class="title-lg">{{failure.title}}</view>
    <view class="hero-desc">{{failure.subtitle}}</view>
    <view class="hero-title">{{failure.message}}</view>
    <view wx:if="{{failure.detailSummary}}" class="hero-summary">{{failure.detailSummary}}</view>
  </view>

  <view class="card section panel">
    <view class="meta-row"><text>错误码</text><text>{{failure.code || '--'}}</text></view>
    <view class="meta-row"><text>任务 ID</text><text>{{failure.taskId || '--'}}</text></view>
    <view class="meta-row"><text>检测时间</text><text>{{failure.createdAt || '--'}}</text></view>
  </view>

  <view class="card section panel reason-panel">
    <view class="title-md">未通过原因</view>
    <view wx:for="{{failure.reasons}}" wx:key="index" class="detail-item">
      <view class="detail-index">{{index + 1}}</view>
      <view class="detail-main">
        <view class="detail-title">{{item.title}}</view>
        <view wx:if="{{item.detail}}" class="detail-sub">{{item.detail}}</view>
        <view wx:if="{{item.reasonCode}}" class="detail-code">原因码：{{item.reasonCode}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{failure.warnings.length}}" class="card section panel warning-panel">
    <view class="title-md">风险提示</view>
    <view wx:for="{{failure.warnings}}" wx:key="index" class="detail-item">
      <view class="detail-index warning">{{index + 1}}</view>
      <view class="detail-main">
        <view class="detail-title">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="card section panel suggestion-panel">
    <view class="title-md">建议处理方式</view>
    <view wx:for="{{failure.suggestions}}" wx:key="index" class="detail-item">
      <view class="detail-index success">{{index + 1}}</view>
      <view class="detail-main">
        <view class="detail-title">{{item}}</view>
      </view>
    </view>
  </view>

  <primary-button text="重新选择照片" bind:tap="retry"></primary-button>
  <view style="height: 12rpx"></view>
  <primary-button text="返回首页" type="secondary" bind:tap="backToUpload"></primary-button>
</view>
