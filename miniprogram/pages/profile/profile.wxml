<view class="container">
  <view class="card section user-card">
    <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
    <view wx:else class="avatar">{{avatarText}}</view>

    <view class="user-copy">
      <view class="user-head">
        <view class="title-md">{{nickname}}</view>
        <view class="login-badge {{isLoggedIn ? 'login-badge-success' : (authLoading ? 'login-badge-pending' : 'login-badge-default')}}">
          {{statusText}}
        </view>
      </view>
      <view class="text-muted welcome-text">{{welcomeText}}</view>
      <view wx:if="{{loginError}}" class="auth-error">{{loginError}}</view>
    </view>
  </view>

  <view class="card section auth-card">
    <view wx:if="{{authLoading}}" class="auth-loading-box">
      <view class="auth-loading-text">正在完成微信登录与用户状态校验</view>
    </view>

    <button
      wx:elif="{{!isLoggedIn}}"
      class="auth-btn auth-btn-primary"
      bindtap="handleLoginTap"
      loading="{{authLoading}}"
      disabled="{{authLoading}}"
    >
      {{loginActionText}}
    </button>

    <view wx:else class="auth-actions">
      <button
        class="auth-btn auth-btn-secondary"
        bindtap="handleRefreshLogin"
        loading="{{authLoading}}"
        disabled="{{authLoading}}"
      >
        重新登录
      </button>
      <button class="auth-btn auth-btn-ghost" bindtap="handleLogoutTap">退出登录</button>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="goHistory">我的作品</view>
    <view class="menu-item" bindtap="goHistory">历史记录</view>
    <view class="menu-item" bindtap="goFaq">常见问题</view>
    <view class="menu-item" bindtap="tapItem">关于我们</view>
  </view>
</view>
