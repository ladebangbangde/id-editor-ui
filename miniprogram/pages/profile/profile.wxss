.profile-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f3f4f6;
}

.placeholder {
  display: flex;
  justify-content: center;
  align-items: center;
  background: #2d6bff;
  color: #fff;
  font-size: 40rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
}

.list-card {
  min-height: 420rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.state-text {
  margin-top: 24rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.error {
  color: #dc2626;
}
