.user-card {
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar,
.avatar-image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.avatar {
  background: linear-gradient(135deg, #4f7cff 0%, #667dff 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 12rpx 24rpx rgba(79, 124, 255, 0.18);
}

.avatar-image {
  display: block;
  background: #eef2ff;
}

.user-copy {
  flex: 1;
  min-width: 0;
}

.user-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.welcome-text {
  margin-top: 8rpx;
}

.auth-error {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #ef4444;
}

.login-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.login-badge-success {
  background: #ecfdf5;
  color: #047857;
}

.login-badge-pending {
  background: #eff6ff;
  color: #1d4ed8;
}

.auth-card {
  padding: 20rpx 24rpx;
}

.auth-actions {
  display: flex;
  gap: 16rpx;
}

.auth-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
}

.auth-btn::after {
  border: none;
}

.auth-btn-primary {
  background: linear-gradient(135deg, #315efb 0%, #5a7cff 100%);
  color: #ffffff;
}

.auth-btn-secondary {
  flex: 1;
  background: #eef4ff;
  color: #315efb;
}

.auth-btn-ghost {
  flex: 1;
  background: #ffffff;
  color: #475569;
  box-shadow: inset 0 0 0 1rpx #dbe4f0;
}

.menu-card {
  padding: 8rpx 20rpx;
}

.menu-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1f5;
  font-size: 28rpx;
  color: #1f2937;
}

.menu-item:last-child {
  border-bottom: none;
}
