<view class="container">
  <view class="card section panel">
    <view class="title-lg">上传照片</view>
    <view class="text-muted current">当前选择：{{sceneInfo.sceneName || '自定义尺寸'}}</view>
    <view class="tips">
      <view>请正对镜头</view>
      <view>光线充足</view>
      <view>背景尽量简洁</view>
      <view>面部清晰无遮挡</view>
    </view>
  </view>

  <view class="card section panel">
    <upload-box image="{{imagePath}}" bind:tap="chooseFromAlbum"></upload-box>
  </view>

  <view class="button-row section">
    <view class="button-item"><primary-button text="拍照" type="secondary" bind:tap="chooseFromCamera"></primary-button></view>
    <view class="button-item"><primary-button text="从相册选择" type="secondary" bind:tap="chooseFromAlbum"></primary-button></view>
  </view>

  <primary-button text="下一步" bind:tap="nextStep"></primary-button>
</view>
