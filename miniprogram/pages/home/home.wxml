<view class="container home-page">
  <view class="card section hero-card">
    <view class="hero-banner">
      <view class="hero-copy">
        <view class="hero-title">棒棒证件照生成器</view>
        <view class="hero-subtitle">报名照 / 证件照 / 简历照快速生成</view>
        <view class="hero-tags">
          <view class="tag hero-tag">常用尺寸</view>
          <view class="tag hero-tag">本地搜索</view>
        </view>
      </view>
      <view class="hero-mini-visual">
        <view class="hero-mini-card hero-mini-card-back"></view>
        <view class="hero-mini-card hero-mini-card-front">
          <view class="hero-mini-avatar"></view>
          <view class="hero-mini-line hero-mini-line-a"></view>
          <view class="hero-mini-line hero-mini-line-b"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="section main-grid">
    <view
      wx:for="{{mainActions}}"
      wx:key="key"
      class="card main-card {{item.cardClass}}"
      data-item="{{item}}"
      bindtap="handleMainActionTap"
    >
      <view class="main-card-head">
        <view class="graphic-icon graphic-icon-{{item.iconType}}">
          <view class="graphic-orb"></view>
          <view class="graphic-plate"></view>
          <view wx:if="{{item.iconType === 'camera'}}" class="graphic-camera-lens"></view>
          <view wx:if="{{item.iconType === 'palette'}}" class="graphic-palette-dot graphic-palette-dot-a"></view>
          <view wx:if="{{item.iconType === 'palette'}}" class="graphic-palette-dot graphic-palette-dot-b"></view>
          <view wx:if="{{item.iconType === 'palette'}}" class="graphic-palette-dot graphic-palette-dot-c"></view>
        </view>
        <view wx:if="{{item.badge}}" class="main-badge">{{item.badge}}</view>
      </view>
      <view class="main-title">{{item.title}}</view>
      <view class="text-muted main-desc">{{item.subtitle}}</view>
    </view>
  </view>

  <view class="card section quick-card">
    <view class="section-head quick-head">
      <view>
        <view class="section-kicker">快捷功能</view>
        <view class="title-md">保留高频工具，减少干扰</view>
      </view>
      <view class="text-muted quick-caption">1 个常用入口</view>
    </view>
    <view
      wx:for="{{quickActions}}"
      wx:key="key"
      class="quick-feature"
      data-item="{{item}}"
      bindtap="handleQuickActionTap"
    >
      <view class="quick-icon-box">
        <view class="suit-icon">
          <view class="suit-icon-collar suit-icon-collar-left"></view>
          <view class="suit-icon-collar suit-icon-collar-right"></view>
          <view class="suit-icon-body"></view>
          <view class="suit-icon-tie"></view>
        </view>
      </view>
      <view class="quick-feature-copy">
        <view class="quick-title">{{item.title}}</view>
        <view class="text-muted quick-desc">{{item.subtitle}}</view>
      </view>
      <view class="quick-arrow">›</view>
    </view>
  </view>

  <view class="card section size-panel">
    <view class="size-panel-head">
      <view>
        <view class="section-kicker">热门尺寸</view>
        <view class="title-lg">先选尺寸，再开始制作</view>
        <view class="text-muted size-panel-desc">{{templateSummary}}</view>
      </view>
      <view class="size-badge">{{activeTabLabel}}</view>
    </view>

    <view class="search-bar {{isSearching ? 'search-bar-active' : ''}}">
      <view class="search-icon">
        <view class="search-icon-circle"></view>
        <view class="search-icon-handle"></view>
      </view>
      <input
        class="search-input"
        placeholder="搜索尺寸名称、场景、标签关键词"
        confirm-type="search"
        value="{{searchKeyword}}"
        bindinput="handleSearchInput"
      />
      <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="handleClearSearch">清除</view>
    </view>

    <scroll-view class="tab-scroll" scroll-x enable-flex show-scrollbar="false">
      <view class="tab-list">
        <view
          wx:for="{{tabs}}"
          wx:key="key"
          class="tab-item {{activeTab === item.key ? 'tab-item-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="handleTabChange"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>

    <view class="size-panel-hint">
      <view class="size-dot"></view>
      <view class="text-muted">{{isSearching ? searchSummary : '点击尺寸模板即可进入上传流程，当前仅搜索本页已加载模板。'}}</view>
    </view>

    <block wx:if="{{loading}}">
      <view class="state-card state-card-embedded">
        <view class="title-md">模板加载中</view>
        <view class="text-muted">正在获取 {{activeTabLabel}} 相关尺寸，请稍候...</view>
      </view>
    </block>

    <block wx:elif="{{error}}">
      <view class="state-card state-card-embedded">
        <view class="title-md">模板加载失败</view>
        <view class="text-muted">{{errorMessage}}</view>
        <view class="state-action">
          <primary-button text="重新加载" bind:tap="handleRetry"></primary-button>
        </view>
      </view>
    </block>

    <block wx:elif="{{isEmpty}}">
      <view class="state-card state-card-embedded">
        <view class="title-md">{{isSearching ? '没有找到匹配尺寸' : '当前分类暂无模板'}}</view>
        <view class="text-muted">{{isSearching ? '试试更短的关键词，或切换其他尺寸分类后再搜索。' : '可以先试试热门尺寸或自定义像素制作。'}}</view>
        <view class="state-action">
          <block wx:if="{{isSearching}}">
            <primary-button text="清空搜索" type="secondary" bind:tap="handleClearSearch"></primary-button>
          </block>
          <block wx:else>
            <primary-button text="去自定义尺寸" bind:tap="goCustomSize"></primary-button>
          </block>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="template-list">
        <view
          wx:for="{{templateList}}"
          wx:key="sceneKey"
          class="template-card"
          data-item="{{item}}"
          bindtap="handleTemplateTap"
        >
          <view class="template-icon template-icon-{{item.iconType}}">
            <view class="template-icon-frame"></view>
            <view class="template-icon-line template-icon-line-a"></view>
            <view class="template-icon-line template-icon-line-b"></view>
          </view>
          <view class="template-main">
            <view class="template-title-row">
              <view class="template-title">{{item.name}}</view>
              <view wx:if="{{item.hot}}" class="hot-badge">热门</view>
            </view>
            <view class="template-meta-row">
              <view class="template-size">{{item.pixelText}}</view>
              <view class="template-scene">{{activeTabLabel}}</view>
            </view>
            <view wx:if="{{item.tip}}" class="template-tip">{{item.tip}}</view>
            <view class="tag-row">
              <view wx:for="{{item.tags}}" wx:key="*this" class="tag template-tag">{{item}}</view>
            </view>
          </view>
          <view class="template-arrow">›</view>
        </view>
      </view>
    </block>
  </view>
</view>
