<view class="container home-page">
  <view class="card section hero-card">
    <view class="hero-top">
      <view class="hero-copy">
        <view class="hero-kicker">棒棒证件照生成</view>
        <view class="title-xl hero-title">常用尺寸与证件照制作，一页直达</view>
        <view class="text-body hero-subtitle">聚焦常用规格、考试报名与证件办理，先选尺寸，再开始制作。</view>
      </view>
      <view class="hero-badge">标准合规</view>
    </view>
    <view class="hero-tags">
      <view class="tag hero-tag">白底 / 蓝底 / 红底</view>
      <view class="tag hero-tag">热门尺寸模板</view>
      <view class="tag hero-tag">棒棒证件照生成</view>
    </view>
  </view>

  <view class="section main-grid">
    <view
      wx:for="{{mainActions}}"
      wx:key="key"
      class="card main-card {{item.cardClass}}"
      data-item="{{item}}"
      bindtap="handleMainActionTap"
    >
      <view class="main-card-head">
        <view class="main-icon {{item.iconClass}}">{{item.iconText}}</view>
        <view wx:if="{{item.badge}}" class="main-badge">{{item.badge}}</view>
      </view>
      <view class="main-title">{{item.title}}</view>
      <view class="text-muted main-desc">{{item.subtitle}}</view>
    </view>
  </view>

  <view class="card section size-focus-card">
    <view class="section-head size-section-head">
      <view>
        <view class="title-md">尺寸选择</view>
        <view class="text-muted size-section-desc">先选尺寸模板，再进入制作流程；搜索只匹配当前分类下的尺寸模板。</view>
      </view>
      <view class="size-highlight-badge">首页重点</view>
    </view>

    <view class="search-bar">
      <view class="search-icon">
        <view class="search-icon-circle"></view>
        <view class="search-icon-handle"></view>
      </view>
      <input
        class="search-input"
        type="text"
        confirm-type="search"
        placeholder="搜索尺寸、场景、标签或说明"
        value="{{searchKeyword}}"
        bindinput="handleSearchInput"
      />
      <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="handleSearchClear">清空</view>
    </view>

    <view class="section tab-scroll-wrap size-tab-scroll-wrap">
      <scroll-view class="tab-scroll" scroll-x enable-flex show-scrollbar="false">
        <view class="tab-list">
          <view
            wx:for="{{tabs}}"
            wx:key="key"
            class="tab-item {{activeTab === item.key ? 'tab-item-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="handleTabChange"
          >
            {{item.label}}
          </view>
        </view>
      </scroll-view>
    </view>

    <block wx:if="{{loading}}">
      <view class="card section state-card size-state-card">
        <view class="title-md">模板加载中</view>
        <view class="text-muted">正在获取 {{activeTabLabel}} 相关尺寸，请稍候...</view>
      </view>
    </block>

    <block wx:elif="{{error}}">
      <view class="card section state-card size-state-card">
        <view class="title-md">模板加载失败</view>
        <view class="text-muted">{{errorMessage}}</view>
        <view class="state-action">
          <primary-button text="重新加载" bind:tap="handleRetry"></primary-button>
        </view>
      </view>
    </block>

    <block wx:elif="{{isEmpty}}">
      <view class="card section state-card size-state-card empty-state-card">
        <view class="title-md">{{searchActive ? '没有找到匹配尺寸' : '当前分类暂无模板'}}</view>
        <view class="text-muted">{{searchActive ? '换个关键词试试，可搜索尺寸名称、场景、标签或说明。' : '可以先试试热门尺寸或切换其他分类。'}}</view>
        <view class="state-action" wx:if="{{searchActive}}">
          <primary-button text="清空搜索" bind:tap="handleSearchClear"></primary-button>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="template-grid size-template-grid">
        <view
          wx:for="{{templateList}}"
          wx:key="sceneKey"
          class="card template-card"
          data-item="{{item}}"
          bindtap="handleTemplateTap"
        >
          <view class="template-head">
            <view class="template-title-wrap">
              <view class="template-title-row">
                <view class="template-title">{{item.name}}</view>
                <view wx:if="{{item.hot}}" class="hot-badge">热门</view>
              </view>
              <view class="text-muted template-size">{{item.pixelText}}</view>
            </view>
            <view class="template-arrow">›</view>
          </view>
          <view wx:if="{{item.tip}}" class="template-tip">{{item.tip}}</view>
          <view class="tag-row">
            <view wx:for="{{item.tags}}" wx:key="*this" class="tag template-tag">{{item}}</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="card section quick-card">
    <view class="section-head quick-section-head">
      <view>
        <view class="title-md">快捷功能</view>
        <view class="text-muted">保留高频入口，减少干扰</view>
      </view>
    </view>
    <view
      wx:for="{{quickActions}}"
      wx:key="key"
      class="quick-feature"
      data-item="{{item}}"
      bindtap="handleQuickActionTap"
    >
      <view class="quick-feature-icon">
        <view class="quick-figure quick-figure-left"></view>
        <view class="quick-figure quick-figure-right"></view>
        <view class="quick-collar"></view>
      </view>
      <view class="quick-feature-copy">
        <view class="quick-title">{{item.title}}</view>
        <view class="text-muted quick-desc">{{item.subtitle}}</view>
      </view>
      <view class="quick-arrow">立即体验</view>
    </view>
  </view>

  <view class="card section knowledge-card" bindtap="goFaq">
    <view class="knowledge-copy">
      <view class="title-md">常见问题 / 小知识</view>
      <view class="text-muted knowledge-desc">第一次做证件照也没关系，这里有一份轻松好懂的小科普，帮你分清一寸、二寸和底色区别。</view>
    </view>
    <view class="knowledge-cat">🐱</view>
  </view>
</view>
