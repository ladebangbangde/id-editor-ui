.home-page {
  padding-bottom: 48rpx;
}

.brand-bar {
  padding: 28rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 246, 233, 0.9) 62%, rgba(255, 238, 216, 0.92) 100%);
  box-shadow: var(--shadow-soft);
}

.brand-bar::before {
  content: '';
  position: absolute;
  right: -42rpx;
  top: -36rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 208, 164, 0.55) 0%, rgba(255, 208, 164, 0) 68%);
  pointer-events: none;
}

.brand-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.brand-title-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.brand-mark {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fffdf9 0%, #fff3e1 100%);
  box-shadow: inset 0 0 0 1rpx rgba(240, 170, 118, 0.28);
  flex-shrink: 0;
}

.brand-mark-dot {
  position: absolute;
  left: 14rpx;
  top: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--warm-600);
}

.brand-mark-card {
  position: absolute;
  right: 12rpx;
  top: 18rpx;
  width: 24rpx;
  height: 28rpx;
  border-radius: 8rpx;
  border: 3rpx solid #f4b37b;
}

.brand-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3a2c1f;
}

.brand-subtitle {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #7a6754;
  line-height: 1.4;
}

.brand-status {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: inset 0 0 0 1rpx rgba(240, 170, 118, 0.28);
  font-size: 18rpx;
  color: var(--warm-600);
  font-weight: 600;
  flex-shrink: 0;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #41c588;
  box-shadow: 0 0 0 6rpx rgba(65, 197, 136, 0.12);
}

.brand-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.brand-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fffefb 0%, #fff2de 100%);
  color: #8a6748;
}

.brand-cta-wrap {
  margin-top: 16rpx;
}

.feature-section {
  margin-top: 12rpx;
}

.feature-section-head {
  margin-bottom: 12rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.section-icon {
  position: relative;
  width: 72rpx;
  height: 60rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffefb 0%, #fff1de 100%);
  box-shadow: inset 0 0 0 1rpx rgba(237, 176, 126, 0.22), 0 8rpx 18rpx rgba(15, 23, 42, 0.04);
  flex-shrink: 0;
}

.section-icon-tools {
  background: linear-gradient(180deg, #fffefb 0%, #fff4e6 100%);
}

.tools-icon-camera {
  position: absolute;
  left: 16rpx;
  top: 20rpx;
  width: 28rpx;
  height: 20rpx;
  border-radius: 8rpx;
  border: 4rpx solid #d88952;
}

.tools-icon-camera::before {
  content: '';
  position: absolute;
  left: 6rpx;
  top: -10rpx;
  width: 10rpx;
  height: 8rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #d88952;
}

.tools-icon-spark {
  position: absolute;
  right: 16rpx;
  bottom: 18rpx;
  width: 10rpx;
  height: 10rpx;
  background: #f09a62;
  transform: rotate(45deg);
  border-radius: 4rpx;
  box-shadow: 0 0 0 6rpx rgba(240, 154, 98, 0.22);
}

.main-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.main-card {
  min-height: 162rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 22rpx rgba(42, 23, 15, 0.06);
}

.main-card-camera {
  background: linear-gradient(180deg, #ffffff 0%, #fff6eb 100%);
}

.main-card-color {
  background: linear-gradient(180deg, #ffffff 0%, #fff8ef 100%);
}

.main-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.main-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.45);
}

.main-icon {
  background: #fff2df;
  color: #d17842;
}

.icon-color {
  background: #fff6ea;
  color: #c66e3b;
}

.icon-camera-shape,
.icon-palette-shape {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.icon-camera-top {
  position: absolute;
  left: 8rpx;
  top: 4rpx;
  width: 16rpx;
  height: 8rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #d17842;
}

.icon-camera-body {
  position: absolute;
  left: 4rpx;
  top: 14rpx;
  width: 40rpx;
  height: 28rpx;
  border-radius: 8rpx;
  border: 4rpx solid #d17842;
}

.icon-camera-lens {
  position: absolute;
  left: 16rpx;
  top: 20rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 4rpx solid #d17842;
}

.icon-palette-main {
  position: absolute;
  left: 6rpx;
  top: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50% 50% 42% 50%;
  background: linear-gradient(180deg, #ffca9d 0%, #e08a52 100%);
  transform: rotate(-20deg);
}

.icon-palette-hole {
  position: absolute;
  right: 10rpx;
  bottom: 8rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #fff6ea;
}

.icon-palette-dot {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
}

.dot-one { left: 14rpx; top: 12rpx; }
.dot-two { left: 24rpx; top: 8rpx; }
.dot-three { left: 28rpx; top: 20rpx; }

.main-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 246, 236, 0.95);
  color: #c87b38;
  font-size: 18rpx;
  font-weight: 600;
}

.main-title {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.main-desc {
  margin-top: 6rpx;
  line-height: 1.4;
  font-size: 22rpx;
}

.size-focus-card {
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #ffffff 0%, #fff6ea 100%);
  box-shadow: 0 22rpx 52rpx rgba(219, 136, 78, 0.2);
  border: 1rpx solid rgba(243, 196, 152, 0.7);
}

.size-focus-card::after {
  content: '';
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 203, 150, 0.4) 0%, rgba(255, 203, 150, 0) 72%);
  pointer-events: none;
}

.size-section-head {
  align-items: center;
}

.section-icon-size {
  background: linear-gradient(180deg, #fffefb 0%, #ffefdb 100%);
}

.size-icon-card {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  width: 30rpx;
  height: 38rpx;
  border-radius: 8rpx;
  border: 3rpx solid #db8d54;
  background: rgba(255, 255, 255, 0.8);
}

.size-icon-ruler {
  position: absolute;
  right: 14rpx;
  top: 20rpx;
  width: 10rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffc996 0%, #df8e55 100%);
}

.size-icon-ruler::before,
.size-icon-ruler::after {
  content: '';
  position: absolute;
  left: 50%;
  width: 14rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  transform: translateX(-50%);
}

.size-icon-ruler::before { top: 8rpx; }
.size-icon-ruler::after { bottom: 8rpx; }

.size-search-wrap {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 249, 241, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow: inset 0 0 0 1rpx rgba(242, 209, 174, 0.7);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 22rpx;
  min-height: 86rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(42, 23, 15, 0.04), inset 0 0 0 1rpx #f4dcc0;
}

.search-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.search-icon-circle {
  position: absolute;
  left: 0;
  top: 0;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #b68e6d;
  border-radius: 50%;
}

.search-icon-handle {
  position: absolute;
  right: 1rpx;
  bottom: 2rpx;
  width: 12rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #b68e6d;
  transform: rotate(45deg);
  transform-origin: center;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #1f2937;
}

.search-clear {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--warm-600);
}

.tab-scroll-wrap {
  margin-bottom: 16rpx;
}

.size-tab-scroll-wrap {
  margin: 18rpx -4rpx 0;
}

.tab-scroll {
  width: 100%;
  white-space: nowrap;
}

.tab-list {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 4rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #f1dcc2;
  color: #6a5a4a;
  font-size: 22rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.04);
}

.tab-item-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #d8ae86;
}

.tab-item-active {
  background: linear-gradient(135deg, var(--warm-500) 0%, var(--warm-600) 100%);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(216, 132, 76, 0.26);
}

.tab-item-active .tab-item-dot {
  background: rgba(255, 255, 255, 0.92);
}

.state-card {
  padding: 28rpx 24rpx;
  text-align: center;
}

.size-state-card {
  margin-top: 6rpx;
  background: #fffdf9;
}

.empty-state-card {
  box-shadow: inset 0 0 0 1rpx #f5e3d0;
}

.state-action {
  margin-top: 20rpx;
}

.template-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.size-template-grid {
  margin-top: 6rpx;
}

.template-card {
  padding: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8f0 100%);
  box-shadow: 0 12rpx 28rpx rgba(61, 35, 16, 0.08);
  border: 1rpx solid #f1dcc4;
}

.template-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.template-title-wrap {
  flex: 1;
  min-width: 0;
}

.template-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.template-icon {
  position: relative;
  width: 36rpx;
  height: 36rpx;
  border-radius: 12rpx;
  background: linear-gradient(180deg, #fff6e8 0%, #fffdf7 100%);
  flex-shrink: 0;
}

.template-icon-photo {
  position: absolute;
  left: 9rpx;
  top: 8rpx;
  width: 18rpx;
  height: 20rpx;
  border-radius: 6rpx;
  border: 2rpx solid #d4854f;
}

.template-icon-photo::before {
  content: '';
  position: absolute;
  right: 2rpx;
  top: 2rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #d4854f;
}

.template-title {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-badge {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #fff4e8;
  color: #d97706;
  font-size: 18rpx;
}

.template-size {
  margin-top: 4rpx;
}

.template-arrow {
  flex-shrink: 0;
  font-size: 34rpx;
  color: #b18d71;
  line-height: 1;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.template-tag {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #fff3e4;
  color: #866a53;
}

.section-subtitle {
  margin-top: 4rpx;
  font-size: 22rpx;
}

.knowledge-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  background: linear-gradient(180deg, #fffdf7 0%, #fff8ef 100%);
}

.knowledge-copy {
  flex: 1;
}

.knowledge-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon-knowledge {
  background: linear-gradient(180deg, #fffefb 0%, #fff5df 100%);
}

.knowledge-icon-book {
  position: absolute;
  left: 16rpx;
  top: 18rpx;
  width: 22rpx;
  height: 28rpx;
  border-radius: 6rpx 4rpx 4rpx 6rpx;
  background: #ffb55a;
}

.knowledge-icon-book::before {
  content: '';
  position: absolute;
  right: -10rpx;
  top: 0;
  width: 18rpx;
  height: 28rpx;
  border-radius: 4rpx 6rpx 6rpx 4rpx;
  background: #ffd289;
}

.knowledge-icon-star {
  position: absolute;
  right: 14rpx;
  top: 14rpx;
  width: 10rpx;
  height: 10rpx;
  background: #ff8d61;
  transform: rotate(45deg);
  border-radius: 4rpx;
}

.knowledge-desc {
  margin-top: 8rpx;
  line-height: 1.5;
}

.knowledge-cat {
  flex-shrink: 0;
  font-size: 46rpx;
  line-height: 1;
  opacity: 0.9;
}
