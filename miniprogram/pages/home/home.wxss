.home-page {
  padding: 12rpx 20rpx 42rpx;
  background: linear-gradient(180deg, #f4f7ff 0%, #f8faff 42%, #fffaf3 100%);
}

.fade-up {
  opacity: 0;
  transform: translateY(18rpx);
  animation: fadeUpIn 380ms ease forwards;
}

.delay-1 { animation-delay: 40ms; }
.delay-2 { animation-delay: 90ms; }
.delay-3 { animation-delay: 140ms; }
.delay-4 { animation-delay: 200ms; }

@keyframes fadeUpIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-panel {
  padding: 18rpx 10rpx 8rpx;
}

.hero-badge {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(60, 98, 246, 0.12);
  color: #3559d8;
  font-size: 18rpx;
  font-weight: 600;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #0f1f56;
}

.hero-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4c5d87;
}

.search-wrap {
  margin-top: 10rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 86rpx;
  padding: 0 22rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(61, 91, 170, 0.12);
  border: 1rpx solid rgba(88, 114, 205, 0.1);
  transition: all 180ms ease;
}

.search-bar:focus-within {
  box-shadow: 0 18rpx 42rpx rgba(55, 89, 193, 0.18);
  border-color: rgba(64, 97, 219, 0.3);
}

.search-icon { position: relative; width: 30rpx; height: 30rpx; }
.search-icon-circle { position: absolute; left: 0; top: 0; width: 20rpx; height: 20rpx; border: 4rpx solid #8aa0bf; border-radius: 50%; }
.search-icon-handle { position: absolute; right: 1rpx; bottom: 2rpx; width: 12rpx; height: 4rpx; border-radius: 999rpx; background: #8aa0bf; transform: rotate(45deg); }
.search-input { flex: 1; min-width: 0; font-size: 26rpx; color: #1f2937; }
.search-clear { font-size: 22rpx; color: #3559d8; }

.section { margin-top: 18rpx; }
.feature-section-head { margin-bottom: 12rpx; }
.section-subtitle { margin-top: 4rpx; font-size: 22rpx; }

.main-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.main-card {
  padding: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(76, 107, 193, 0.11);
  box-shadow: 0 10rpx 24rpx rgba(39, 58, 110, 0.08);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.main-card:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 14rpx rgba(39, 58, 110, 0.08);
}

.main-card-color { background: linear-gradient(155deg, #ffffff 0%, #eef3ff 100%); }
.main-card-crop { background: linear-gradient(155deg, #ffffff 0%, #f4f1ff 100%); }
.main-card-history { background: linear-gradient(155deg, #ffffff 0%, #fff5ec 100%); }

.main-card-head { display: flex; align-items: center; justify-content: space-between; }
.main-icon { position: relative; width: 64rpx; height: 64rpx; border-radius: 18rpx; }
.icon-color { background: #eef3ff; }
.icon-crop { background: #f3eefe; }
.icon-history { background: #fff2e5; }

.main-title { margin-top: 12rpx; font-size: 24rpx; font-weight: 700; color: #101828; }
.main-desc { margin-top: 4rpx; font-size: 20rpx; color: #5f6d89; line-height: 1.35; }
.main-badge { padding: 4rpx 12rpx; border-radius: 999rpx; font-size: 18rpx; background: #ffe8d2; color: #b45309; }

.icon-palette-shape,
.icon-crop-shape,
.icon-history-shape { position: relative; width: 40rpx; height: 40rpx; margin: 12rpx auto 0; }
.icon-palette-main { position: absolute; left: 4rpx; top: 4rpx; width: 30rpx; height: 30rpx; border-radius: 50% 50% 42% 50%; background: linear-gradient(180deg, #6c8dff 0%, #4e6bef 100%); transform: rotate(-20deg); }
.icon-palette-hole { position: absolute; right: 8rpx; bottom: 7rpx; width: 8rpx; height: 8rpx; border-radius: 50%; background: #eef3ff; }
.icon-palette-dot { position: absolute; width: 6rpx; height: 6rpx; border-radius: 50%; background: #fff; }
.dot-one { left: 10rpx; top: 12rpx; }
.dot-two { left: 18rpx; top: 9rpx; }
.dot-three { left: 21rpx; top: 17rpx; }

.icon-crop-corner { position: absolute; width: 14rpx; height: 14rpx; border-color: #7152d8; border-style: solid; }
.corner-lt { left: 0; top: 0; border-width: 4rpx 0 0 4rpx; border-radius: 6rpx 0 0 0; }
.corner-rt { right: 0; top: 0; border-width: 4rpx 4rpx 0 0; border-radius: 0 6rpx 0 0; }
.corner-lb { left: 0; bottom: 0; border-width: 0 0 4rpx 4rpx; border-radius: 0 0 0 6rpx; }
.corner-rb { right: 0; bottom: 0; border-width: 0 4rpx 4rpx 0; border-radius: 0 0 6rpx 0; }

.icon-history-ring { position: absolute; left: 4rpx; top: 4rpx; width: 30rpx; height: 30rpx; border: 4rpx solid #d97706; border-radius: 50%; }
.icon-history-hand { position: absolute; left: 20rpx; top: 12rpx; width: 4rpx; height: 12rpx; border-radius: 999rpx; background: #d97706; box-shadow: -8rpx 10rpx 0 0 #d97706; transform-origin: bottom; }

.size-focus-card {
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(160deg, #ffffff 0%, #f5f8ff 65%, #fff9f1 100%);
  border: 1rpx solid rgba(75, 107, 193, 0.12);
  box-shadow: 0 20rpx 44rpx rgba(36, 64, 143, 0.12);
}

.section-head { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.size-main-title { color: #10203f; font-size: 34rpx; font-weight: 800; }
.all-entry { padding: 10rpx 16rpx; border-radius: 999rpx; background: rgba(69, 97, 210, 0.12); color: #3e5ac8; font-size: 22rpx; }

.size-tab-scroll-wrap { margin: 14rpx -2rpx 0; }
.tab-scroll { width: 100%; white-space: nowrap; }
.tab-list { display: inline-flex; gap: 10rpx; padding: 6rpx 4rpx; }
.tab-item { display: inline-flex; align-items: center; gap: 8rpx; padding: 12rpx 22rpx; border-radius: 999rpx; background: #fff; border: 1rpx solid #e5ebf7; color: #4c5b76; font-size: 22rpx; }
.tab-item-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #a8b6d5; }
.tab-item-active { color: #fff; border-color: transparent; background: linear-gradient(135deg, #3d5ef3 0%, #6a7dff 100%); box-shadow: 0 10rpx 24rpx rgba(62, 91, 217, 0.24); }
.tab-item-active .tab-item-dot { background: rgba(255, 255, 255, 0.9); }

.template-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14rpx; margin-top: 12rpx; }
.template-card { padding: 20rpx; border-radius: 20rpx; border: 1rpx solid #e7edf8; background: #fff; box-shadow: 0 10rpx 24rpx rgba(25, 38, 81, 0.08); transition: transform 160ms ease; }
.template-card:active { transform: scale(0.985); }
.template-head { display: flex; justify-content: space-between; gap: 10rpx; }
.template-title-wrap { flex: 1; min-width: 0; }
.template-title-row { display: flex; align-items: center; gap: 8rpx; }
.template-icon { position: relative; width: 34rpx; height: 34rpx; border-radius: 10rpx; background: linear-gradient(180deg, #edf4ff 0%, #f8fbff 100%); }
.template-icon-photo { position: absolute; left: 9rpx; top: 7rpx; width: 16rpx; height: 18rpx; border-radius: 5rpx; border: 2rpx solid #5c7cf1; }
.template-title { font-size: 25rpx; font-weight: 700; color: #111827; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.template-size { margin-top: 4rpx; font-size: 22rpx; color: #4d5f87; }
.hot-badge { padding: 4rpx 10rpx; border-radius: 999rpx; background: #ffe7cf; color: #c46b06; font-size: 18rpx; }
.template-arrow { color: #9cadca; font-size: 30rpx; }
.tag-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 12rpx; }
.template-tag { background: #ecf2ff; color: #4f6191; }
.template-tip { margin-top: 10rpx; font-size: 20rpx; color: #73809d; line-height: 1.4; min-height: 56rpx; }

.state-card { padding: 28rpx 24rpx; text-align: center; }
.size-state-card { margin-top: 8rpx; }
.state-action { margin-top: 20rpx; }

.knowledge-card {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(180deg, #fffdfa 0%, #fff4e7 100%);
  border-color: #f6e7d2;
}
.knowledge-desc { margin-top: 6rpx; }
.knowledge-arrow { font-size: 22rpx; color: #b45309; font-weight: 600; }
