.progress-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #f6f8ff 0%, #f7f5f2 52%, #f6f8ff 100%);
}

.hero {
  padding: 36rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(165deg, #ffffff 0%, #fffaf4 100%);
  border: 1rpx solid #f0e6d7;
}

.hero-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #ffd9a2 0%, #ffbc68 40%, #ffcc88 100%);
  margin: 0 auto 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(255, 179, 94, 0.26);
  animation: breathe 1.9s ease-in-out infinite;
}

@keyframes breathe {
  0% { transform: scale(0.98); opacity: 0.9; }
  50% { transform: scale(1.02); opacity: 1; }
  100% { transform: scale(0.98); opacity: 0.9; }
}

.hero-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  line-height: 1.35;
  color: #0f172a;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 8rpx;
  text-align: center;
  color: #6b7280;
  font-size: 24rpx;
}

.progress-wrap {
  margin-top: 26rpx;
}

.progress-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.stage-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
}

.progress-text {
  font-size: 24rpx;
  color: #315efb;
  font-weight: 600;
}

.stage-desc {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.progress-track {
  margin-top: 16rpx;
  width: 100%;
  height: 16rpx;
  border-radius: 999rpx;
  background: #ecf1fb;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #5f84ff 0%, #76a2ff 50%, #ffcc8a 100%);
  transition: width 260ms ease;
}

.stage-list {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
}

.stage-item {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 2rpx;
}

.stage-dot {
  width: 30rpx;
  height: 30rpx;
  margin-top: 6rpx;
  border-radius: 50%;
  border: 2rpx solid #c7d2fe;
  color: #315efb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  background: #f8faff;
}

.stage-dot.done {
  background: #dbeafe;
  border-color: #7ca6ff;
}

.stage-dot.doing {
  border-color: #315efb;
  box-shadow: 0 0 0 8rpx rgba(49, 94, 251, 0.12);
}

.stage-dot.todo {
  opacity: 0.5;
}

.stage-item-title {
  display: block;
  color: #334155;
  font-size: 26rpx;
  font-weight: 600;
}

.stage-item-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #7a8798;
}

.stage-item.todo .stage-item-title,
.stage-item.todo .stage-item-desc {
  color: #9aa5b5;
}

.stage-item.doing .stage-item-title {
  color: #1f3eb8;
}

.tips {
  margin-top: 18rpx;
  padding: 22rpx;
  color: #64748b;
  font-size: 23rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.footer-actions {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.status-failure {
  margin-top: 24rpx;
  border-radius: 22rpx;
  background: #fff7f5;
  border: 1rpx solid #ffdacc;
  padding: 20rpx;
}

.status-title {
  display: block;
  color: #b44b38;
  font-size: 28rpx;
  font-weight: 600;
}

.status-desc {
  display: block;
  margin-top: 8rpx;
  color: #8f5a4b;
  font-size: 24rpx;
  line-height: 1.5;
}
