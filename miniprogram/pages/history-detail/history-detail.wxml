<view class="container">
  <block wx:if="{{record}}">
    <view class="card section panel">
      <image class="preview" src="{{record.displayUrl || record.previewUrl}}" mode="aspectFit"></image>
    </view>

    <view class="card section panel">
      <view class="meta-row"><text>照片类型</text><text>{{record.sceneName}}</text></view>
      <view class="meta-row"><text>适用说明</text><text>{{record.sceneHint || '适合常见证件照场景'}}</text></view>
      <view class="meta-row"><text>尺寸信息</text><text>{{record.sizeText}}</text></view>
      <view class="meta-row"><text>背景颜色</text><text>{{record.backgroundColor}}</text></view>
      <view class="meta-row"><text>照片状态</text><text>{{record.qualityStatus || '--'}}</text></view>
      <view class="meta-row"><text>质量提示</text><text>{{record.qualityMessage || '请看一眼照片细节，满意就可以保存啦'}}</text></view>
      <view class="meta-row"><text>保存说明</text><text>{{record.fileDesc}}</text></view>
      <view class="meta-row"><text>创建时间</text><text>{{record.createdAt}}</text></view>
    </view>

    <view wx:if="{{record.warnings.length}}" class="card section panel warning-panel">
      <view class="title-md">建议注意</view>
      <view wx:for="{{record.warnings}}" wx:key="index" class="warning-item">
        <view class="warning-dot"></view>
        <view class="warning-text">{{item}}</view>
      </view>
    </view>

    <view class="button-row section button-row-top">
      <view class="button-item"><primary-button text="保存普通图" type="secondary" bind:tap="savePreview"></primary-button></view>
      <view class="button-item"><primary-button text="保存高清图" bind:tap="saveHd"></primary-button></view>
    </view>
    <view wx:if="{{record.printLayoutUrl}}" class="section">
      <primary-button text="保存排版图" type="secondary" bind:tap="saveLayout"></primary-button>
    </view>
    <view class="button-row section">
      <view class="button-item"><primary-button text="按此参数重新编辑" type="secondary" bind:tap="remake"></primary-button></view>
      <view class="button-item"><primary-button text="删除" type="secondary" bind:tap="handleDelete"></primary-button></view>
    </view>
  </block>
  <block wx:else>
    <view class="card panel">未找到对应历史记录</view>
  </block>
</view>
