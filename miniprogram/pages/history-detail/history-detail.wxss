.section {
  margin-bottom: 20rpx;
}

.img-group {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.img-item {
  flex: 1;
}

.img-title {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.img {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  color: #374151;
}

.meta-row:last-child {
  border-bottom: none;
}
