.panel { padding: 24rpx; }
.preview { width: 100%; height: 420rpx; border-radius: 18rpx; background: #f8fafc; }
.meta-row { display: flex; justify-content: space-between; gap: 16rpx; padding: 10rpx 0; border-bottom: 1rpx solid #edf1f5; color: #334155; }
.meta-row:last-child { border-bottom: none; }
.button-row { display: flex; gap: 12rpx; }
.button-item { flex: 1; }
