.panel { padding: 24rpx; }
.preview { width: 100%; height: 420rpx; border-radius: 18rpx; background: #f8fafc; }
.candidate-row { margin-top: 16rpx; display: flex; gap: 12rpx; }
.candidate-item { flex: 1; padding: 8rpx; border-radius: 14rpx; border: 1rpx solid #e2e8f0; background: #fff; }
.candidate-item-active { border-color: #60a5fa; background: #f0f9ff; }
.candidate-thumb { width: 100%; height: 120rpx; border-radius: 10rpx; background: #f1f5f9; }
.candidate-tag { margin-top: 6rpx; font-size: 22rpx; color: #475569; text-align: center; }
.meta-row { display: flex; justify-content: space-between; gap: 16rpx; padding: 10rpx 0; border-bottom: 1rpx solid #edf1f5; color: #334155; font-size: 25rpx; }
.meta-row:last-child { border-bottom: none; }
.button-row { display: flex; gap: 12rpx; }
.button-row-top { margin-bottom: 12rpx; }
.button-item { flex: 1; }
.warning-panel { background: #fffdf5; border: 1rpx solid #fde68a; }
.warning-item { display: flex; gap: 14rpx; margin-top: 16rpx; padding: 14rpx 16rpx; border-radius: 16rpx; background: rgba(255, 255, 255, 0.78); }
.warning-dot { width: 14rpx; height: 14rpx; margin-top: 10rpx; border-radius: 50%; background: #f59e0b; flex-shrink: 0; }
.warning-text { color: #92400e; font-size: 24rpx; line-height: 1.7; }
