
.result-page {
  padding-bottom: 40rpx;
}

.result-header,
.preview-card,
.summary-card,
.tip-card {
  padding: 24rpx;
}

.result-header {
  background: linear-gradient(135deg, #fffaf7 0%, #ffffff 42%, #f5f8ff 100%);
}

.result-header-top,
.preview-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.result-desc {
  margin-top: 8rpx;
  line-height: 1.65;
}

.result-status {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(49, 94, 251, 0.1);
  color: #315efb;
  font-size: 22rpx;
  font-weight: 600;
}

.result-status-mock {
  background: rgba(255, 125, 89, 0.12);
  color: #ff7d59;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.result-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f4f7ff;
  color: #4e63a7;
  font-size: 22rpx;
}

.compare-switch {
  display: inline-flex;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #f4f6fa;
}

.compare-pill {
  min-width: 108rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  color: #667085;
}

.compare-pill-active {
  background: #ffffff;
  color: #315efb;
  font-weight: 600;
  box-shadow: 0 6rpx 18rpx rgba(17, 24, 39, 0.06);
}

.result-image {
  width: 100%;
  height: 760rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef3fb 100%);
}

.preview-caption {
  margin-top: 14rpx;
  font-size: 23rpx;
  color: #677489;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  padding: 14rpx 0;
  font-size: 25rpx;
  color: #334155;
  border-bottom: 1rpx solid #edf1f5;
}

.meta-row:last-child {
  border-bottom: none;
}

.meta-value-emphasis {
  color: #10203a;
  font-weight: 600;
  text-align: right;
}

.tip-item {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #fff8f3;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff875d;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #7a4f35;
  line-height: 1.65;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.ghost-home {
  height: 86rpx;
  border-radius: 22rpx;
  background: #eef2f8;
  color: #41506c;
  font-size: 25rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
