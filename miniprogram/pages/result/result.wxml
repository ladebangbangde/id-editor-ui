<view class="container">
  <view class="card section status">
    <view wx:if="{{result.reviewState === 'failed'}}" class="title-lg">检测未通过</view>
    <view wx:elif="{{result.reviewState === 'warning'}}" class="title-lg">制作完成（有提醒）</view>
    <view wx:else class="title-lg">制作完成</view>
    <view wx:if="{{result.reviewState === 'failed'}}" class="text-muted">检测结果未通过，建议根据提示调整后重新生成。</view>
    <view wx:else class="text-muted">照片已经准备好啦，确认一下效果后就可以直接保存到相册。</view>
  </view>

  <view class="card section panel quality-banner {{result.riskLevel === 'failed' ? 'quality-banner-warning' : (result.riskLevel === 'warning' ? 'quality-banner-warning' : 'quality-banner-passed')}}">
    <view class="quality-banner-header">
      <view class="title-md">{{result.riskTitle}}</view>
      <view class="quality-tag {{result.riskLevel === 'failed' ? 'quality-tag-warning' : (result.riskLevel === 'warning' ? 'quality-tag-warning' : 'quality-tag-passed')}}">{{result.qualityText}}</view>
    </view>
    <view class="quality-message">{{result.riskMessage}}</view>
    <view class="quality-count">{{result.riskCountText}}</view>
  </view>

  <view class="card section panel">
    <view class="title-md">结果展示</view>
    <view class="preview-list">
      <view class="preview-item">
        <view class="text-muted">普通图（适合预览/分享）</view>
        <block wx:if="{{result.previewUrl && !previewImageFailed}}">
          <image class="preview" src="{{result.previewUrl}}" mode="aspectFit" binderror="handlePreviewImageError"></image>
        </block>
        <view wx:else class="preview-fallback">普通图加载失败，请稍后重试或重新生成</view>
      </view>
      <view class="preview-item">
        <view class="text-muted">高清图（适合打印/正式提交）</view>
        <block wx:if="{{(result.hdUrl || result.resultUrl || result.previewUrl) && !hdImageFailed}}">
          <image class="preview" src="{{result.hdUrl || result.resultUrl || result.previewUrl}}" mode="aspectFit" binderror="handleHdImageError"></image>
        </block>
        <view wx:else class="preview-fallback">高清图加载失败，请检查网络或图片地址有效性</view>
      </view>
    </view>
  </view>

  <view class="card section panel">
    <view class="meta-row"><text>照片类型</text><text>{{result.sceneName}}</text></view>
    <view class="meta-row"><text>适用说明</text><text>{{result.sceneHint || '适合常见证件照使用场景'}}</text></view>
    <view class="meta-row"><text>尺寸信息</text><text>{{result.sizeText || '--'}}</text></view>
    <view class="meta-row"><text>底色</text><text>{{result.backgroundColorLabel || result.backgroundColor || '--'}}</text></view>
    <view class="meta-row"><text>照片状态</text><text>{{result.status || '--'}}</text></view>
    <view class="meta-row"><text>质量提示</text><text class="meta-value-emphasis">{{result.qualityMessage || '请看一眼照片细节，满意就可以保存啦'}}</text></view>
    <view class="meta-row"><text>像素尺寸</text><text>{{result.width || '--'}} × {{result.height || '--'}} px</text></view>
    <view class="meta-row"><text>保存说明</text><text>{{result.fileDesc}}</text></view>
  </view>

  <view wx:if="{{result.warnings.length}}" class="card section panel warning-panel">
    <view class="warning-panel-header">
      <view class="title-md">小提醒</view>
      <view class="warning-badge">{{result.warnings.length}} 条</view>
    </view>
    <view wx:for="{{result.warnings}}" wx:key="*this" class="warning-item">
      <view class="warning-dot"></view>
      <view class="warning-content">{{item}}</view>
    </view>
  </view>

  <view class="button-row section">
    <view class="button-item"><primary-button text="保存普通图" type="secondary" bind:tap="savePreview"></primary-button></view>
    <view class="button-item"><primary-button text="保存高清图" bind:tap="saveHd"></primary-button></view>
  </view>
  <view wx:if="{{result.printLayoutUrl}}" class="section">
    <primary-button text="保存排版图" type="secondary" bind:tap="saveLayout"></primary-button>
  </view>
  <view class="card section faq-card" bindtap="goFaq">
    <view class="faq-title">常见问题 / 小知识</view>
    <view class="text-muted faq-desc">不确定该选哪种尺寸，或者想知道白底、蓝底怎么选？点这里看看，很快就懂。</view>
    <view class="faq-cat">🐱</view>
  </view>
  <view class="button-row section">
    <view class="button-item"><primary-button text="返回编辑参数" type="secondary" bind:tap="remake"></primary-button></view>
    <view class="button-item"><primary-button text="重新选尺寸" type="secondary" bind:tap="reselectSize"></primary-button></view>
  </view>
  <primary-button text="从头重拍" type="secondary" bind:tap="retake"></primary-button>
</view>
