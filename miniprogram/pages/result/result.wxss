.section {
  margin-bottom: 18rpx;
}

.images-wrap {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.img-col {
  flex: 1;
}

.img-title {
  display: block;
  margin-bottom: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.img {
  width: 100%;
  height: 260rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.img-fallback {
  display: flex;
  justify-content: center;
  align-items: center;
  color: #9ca3af;
  font-size: 24rpx;
}

.meta {
  margin-top: 10rpx;
  color: #374151;
}

.notice {
  color: #6b7280;
  font-size: 24rpx;
}
