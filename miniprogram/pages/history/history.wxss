.history-page {
  padding-bottom: 24rpx;
}

.panel {
  padding: 24rpx;
}

.header-card {
  position: sticky;
  top: 0;
  z-index: 2;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.manage-btn {
  min-width: 108rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 24rpx;
  text-align: center;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty {
  padding: 30rpx;
  text-align: center;
}

.btn-wrap {
  margin-top: 16rpx;
}

.manage-bar-safe {
  height: 156rpx;
}

.manage-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(17, 24, 39, 0.95);
  color: #fff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.16);
}

.manage-summary {
  font-size: 26rpx;
  font-weight: 600;
}

.manage-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bar-btn {
  min-width: 132rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  text-align: center;
}

.bar-btn-light {
  background: #fff;
  color: #111827;
}

.bar-btn-danger {
  background: #ef4444;
  color: #fff;
}

.bar-btn.disabled {
  opacity: 0.45;
}

.edit-mask {
  position: fixed;
  inset: 0;
  z-index: 10;
  background: rgba(15, 23, 42, 0.48);
  display: flex;
  align-items: flex-end;
}

.edit-drawer {
  width: 100%;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #fff;
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.drawer-close {
  font-size: 24rpx;
  color: #6b7280;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #374151;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #dbe2ea;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 26rpx;
}

.drawer-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.drawer-btn {
  flex: 1;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  text-align: center;
}

.drawer-btn-ghost {
  background: #f3f4f6;
  color: #374151;
}

.drawer-btn-primary {
  background: #2563eb;
  color: #fff;
}
