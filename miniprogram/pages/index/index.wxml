<view class="container">
  <view class="card hero">
    <view class="section-title">AI证件照制作</view>
    <view class="section-desc">上传自拍，一键生成专业证件照</view>
  </view>

  <view class="card section">
    <view class="section-title">Upload Selfie</view>
    <view class="upload-box" bindtap="handleChooseImage">
      <block wx:if="{{localImagePath}}">
        <image class="preview-image" mode="aspectFit" src="{{localImagePath}}"></image>
      </block>
      <block wx:else>
        <view class="upload-placeholder">
          <text class="upload-plus">＋</text>
          <text class="upload-text">{{pageText.UPLOAD_HINT}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="card section">
    <view class="section-title">Select Size</view>
    <size-selector value="{{selectedSize}}" options="{{sizeOptions}}" bind:change="onSizeChange"></size-selector>
  </view>

  <view class="card section">
    <view class="section-title">Select Background</view>
    <color-selector value="{{selectedColor}}" options="{{colorOptions}}" bind:change="onColorChange"></color-selector>
  </view>

  <view class="section">
    <primary-button text="立即生成" loading="{{generating}}" bind:tap="handleGenerate"></primary-button>
  </view>

  <view class="card section">
    <view class="section-title">Why Choose This Tool</view>
    <view class="feature-item" wx:for="{{pageText.FEATURE_LIST}}" wx:key="*this">• {{item}}</view>
  </view>
</view>
