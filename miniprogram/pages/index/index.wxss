.hero {
  margin-bottom: 20rpx;
}

.section {
  margin-bottom: 20rpx;
}

.upload-box {
  margin-top: 16rpx;
  width: 100%;
  min-height: 360rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #c9d2e3;
  background: #fafcff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-placeholder {
  text-align: center;
  color: #6b7280;
  padding: 40rpx;
}

.upload-plus {
  display: block;
  font-size: 68rpx;
  color: #2d6bff;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
}

.preview-image {
  width: 100%;
  min-height: 360rpx;
}

.feature-item {
  margin-top: 12rpx;
  color: #374151;
  font-size: 25rpx;
}
