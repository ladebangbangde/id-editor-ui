<view class="container">
  <view class="card section panel">
    <view class="title-lg">参数配置</view>
    <view class="text-muted">支持重新选尺寸并切换底色。</view>
  </view>

  <view class="card section panel">
    <view class="title-md">原图</view>
    <image wx:if="{{draft.sourceImagePath}}" class="preview" src="{{draft.sourceImagePath}}" mode="aspectFit"></image>
    <view wx:else class="text-muted">还没有原图，请先上传</view>
  </view>

  <view class="card section panel">
    <view class="title-md">当前尺寸</view>
    <view class="meta-row"><text>{{draft.sceneName || draft.selectedScene.sceneName || '未选择尺寸'}}</text><text>{{draft.selectedScene.widthMm || '--'}}×{{draft.selectedScene.heightMm || '--'}}mm</text></view>
    <view class="text-muted">{{draft.sizeText || '请选择证件照尺寸'}}</view>
    <primary-button text="返回重新选尺寸" type="secondary" bind:tap="goSelectSize"></primary-button>
  </view>

  <view class="card section panel">
    <view class="title-md">背景色</view>
    <view class="text-muted">当前：{{draft.backgroundColorLabel || '白色'}}</view>
    <color-picker value="{{selectedColor}}" bind:change="onColorChange"></color-picker>
  </view>

  <primary-button text="生成结果" loading="{{generating}}" bind:tap="handleGenerate"></primary-button>
  <progress-modal
    visible="{{progressVisible}}"
    stageCode="{{progressStageCode}}"
    stageName="{{progressStageName}}"
    stageDescription="{{progressStageDescription}}"
    progress="{{progressValue}}"
    elapsedSeconds="{{elapsedSeconds}}"
    status="{{progressStatus}}"
    errorMessage="{{progressErrorMessage}}"
    bind:retry="onRetryGenerate"
  ></progress-modal>
</view>
