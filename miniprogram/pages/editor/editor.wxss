.panel { padding: 24rpx; }
.meta-row { display: flex; justify-content: space-between; align-items: center; margin: 12rpx 0; color: #334155; }
.preview-wrap { margin-top: 14rpx; height: 420rpx; border-radius: 20rpx; background: #f8fafc; border: 1rpx solid #e6ecf3; display: flex; align-items: center; justify-content: center; }
.preview { width: 100%; height: 420rpx; border-radius: 16rpx; background: #f8fafc; }
.waiting { color: #94a3b8; font-size: 24rpx; }
.button-row { display: flex; gap: 12rpx; }
.button-item { flex: 1; }
.warning-panel { background: #fff7ed; border: 1rpx solid #fed7aa; }
.warning-text { margin-top: 8rpx; color: #c2410c; font-size: 24rpx; line-height: 1.6; }

.remake-header {
  background: linear-gradient(180deg, #f8faff 0%, #ffffff 100%);
  border: 1rpx solid #dbe5ff;
}

.inherit-tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.inherit-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #315efb;
  font-size: 22rpx;
}

.candidate-row {
  margin-top: 14rpx;
  display: flex;
  gap: 16rpx;
}

.candidate-item {
  flex: 1;
  border: 2rpx solid #dbe5ff;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f8fafc;
}

.candidate-item-active {
  border-color: #315efb;
  box-shadow: 0 10rpx 22rpx rgba(49, 94, 251, 0.16);
}

.candidate-thumb {
  width: 100%;
  height: 200rpx;
  background: #eef2f7;
}

.candidate-tag {
  padding: 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #334155;
}
