<view class="container">
  <view class="card section panel">
    <view class="title-lg">选择证件照尺寸</view>
    <view class="text-muted">先确认尺寸，再进入参数配置页生成结果。</view>
    <input class="input" type="text" placeholder="搜索尺寸 / 场景" value="{{keyword}}" bindinput="handleKeywordInput" />
  </view>

  <view wx:if="{{recentSizes.length}}" class="card section panel">
    <view class="title-md">最近使用</view>
    <view class="size-list">
      <view wx:for="{{recentSizes}}" wx:key="code" class="size-item {{selectedSizeCode===item.code?'active':''}}" data-code="{{item.code}}" bindtap="handleSelectSize">
        <view>{{item.name}}</view>
        <view class="text-muted">{{item.sizeText}}</view>
      </view>
    </view>
  </view>

  <view class="card section panel">
    <view class="title-md">热门标准尺寸</view>
    <view class="size-list">
      <view wx:for="{{hotSizes}}" wx:key="code" class="size-item {{selectedSizeCode===item.code?'active':''}}" data-code="{{item.code}}" bindtap="handleSelectSize">
        <view>{{item.name}}</view>
        <view class="text-muted">{{item.usage}}</view>
        <view class="text-muted">{{item.sizeText}} / {{item.pixelText}}</view>
      </view>
    </view>
  </view>

  <view class="card section panel">
    <view class="title-md">全部尺寸</view>
    <view class="size-list">
      <view wx:for="{{filteredSizes}}" wx:key="code" class="size-item {{selectedSizeCode===item.code?'active':''}}" data-code="{{item.code}}" bindtap="handleSelectSize">
        <view>{{item.name}}</view>
        <view class="text-muted">{{item.usage}}</view>
        <view class="text-muted">{{item.sizeText}} / {{item.pixelText}}</view>
      </view>
    </view>
  </view>

  <view class="card section panel">
    <view class="title-md">自定义尺寸</view>
    <view class="text-muted">适用于特殊尺寸场景</view>
    <view class="text-muted">若服务端暂不支持，将按一寸兜底生成（后续支持将自动切换）。</view>
    <primary-button text="{{customMode ? '取消自定义' : '使用自定义尺寸'}}" type="secondary" bind:tap="toggleCustomMode"></primary-button>
    <block wx:if="{{customMode}}">
      <view class="field">
        <text class="label">宽度（mm）</text>
        <input class="input" type="digit" value="{{widthMm}}" bindinput="onWidthInput" />
      </view>
      <view class="field">
        <text class="label">高度（mm）</text>
        <input class="input" type="digit" value="{{heightMm}}" bindinput="onHeightInput" />
      </view>
    </block>
  </view>

  <primary-button text="下一步：参数配置" bind:tap="nextStep"></primary-button>
</view>
