page {
  background: #f5f7fb;
  color: #1f2a37;
  font-size: 28rpx;
  box-sizing: border-box;
}

view,
text,
image,
button {
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.section-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.muted {
  color: #6b7280;
}

.error-text {
  color: #dc2626;
}
