.record-card {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  border: 1rpx solid #e8edf3;
  border-radius: 18rpx;
  padding: 16rpx;
  background: #fff;
}

.record-card-manage {
  align-items: center;
}

.selector-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  padding-top: 12rpx;
}

.selector {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.selector-active {
  border-color: #2563eb;
  background: #2563eb;
}

.selector-icon {
  color: #fff;
  font-size: 20rpx;
  line-height: 1;
}

.thumb {
  width: 130rpx;
  height: 166rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
}

.thumb-fallback {
  border: 1rpx dashed #cbd5e1;
  color: #94a3b8;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.main {
  flex: 1;
}

.row-between {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.name {
  flex: 1;
  font-size: 27rpx;
  color: #111827;
  font-weight: 600;
}

.status {
  font-size: 22rpx;
  color: #0f766e;
}

.meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 16rpx;
}

.action-btn {
  min-width: 96rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
  text-align: center;
}

.action-btn-danger {
  background: #fef2f2;
  color: #ef4444;
}
