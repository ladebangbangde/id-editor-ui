.record-card { display:flex; gap:14rpx; border:1rpx solid #e8edf3; border-radius:18rpx; padding:12rpx; background:#fff; }
.thumb { width:130rpx; height:166rpx; border-radius:12rpx; background:#f1f5f9; }
.main { flex:1; }
.row-between { display:flex; justify-content:space-between; }
.name { font-size:27rpx; color:#111827; font-weight:600; }
.status { font-size:22rpx; color:#0f766e; }
.meta { margin-top:6rpx; font-size:22rpx; color:#64748b; }
