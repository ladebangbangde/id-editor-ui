.record-card {
  display: flex;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.04);
}

.thumb {
  width: 160rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.right {
  flex: 1;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.label {
  color: #6b7280;
  font-size: 24rpx;
}

.value {
  color: #111827;
  font-size: 24rpx;
}

.status {
  color: #2d6bff;
  font-weight: 600;
}
