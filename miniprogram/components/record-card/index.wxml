<view class="record-card" bindtap="handleTap">
  <image class="thumb" src="{{record.previewUrl}}" mode="aspectFill"></image>
  <view class="main">
    <view class="row-between">
      <text class="name">{{record.sceneName}}</text>
      <text class="status">{{statusText}}</text>
    </view>
    <view class="meta">尺寸：{{record.sizeText}}</view>
    <view class="meta">背景：{{record.backgroundColor}}</view>
    <view class="meta">时间：{{record.createdAt}}</view>
  </view>
</view>
