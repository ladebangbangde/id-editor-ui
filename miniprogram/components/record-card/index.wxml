<view class="record-card {{manageMode ? 'record-card-manage' : ''}}" bindtap="handleTap">
  <view wx:if="{{manageMode}}" class="selector-wrap" catchtap="handleToggle">
    <view class="selector {{record.selected ? 'selector-active' : ''}}">
      <text wx:if="{{record.selected}}" class="selector-icon">✓</text>
    </view>
  </view>

  <view class="thumb-group">
    <block wx:if="{{candidates.length}}">
      <view
        wx:for="{{candidates}}"
        wx:key="candidateId"
        class="candidate-block"
        data-index="{{index}}"
        catchtap="handleCandidateTap"
      >
        <image class="thumb {{candidates.length > 1 ? 'thumb-half' : ''}}" src="{{item.imageUrl}}" mode="aspectFill" binderror="handleImageError"></image>
        <view wx:if="{{item.sourceLabel || item.label}}" class="candidate-label">{{item.sourceLabel || item.label}}</view>
      </view>
    </block>
    <view wx:else class="thumb thumb-fallback">暂无预览</view>
  </view>

  <view class="main">
    <view class="row-between">
      <text class="name">{{record.sceneName}}</text>
      <text class="status">{{statusText}}</text>
    </view>
    <view class="meta">尺寸：{{record.sizeText}}</view>
    <view class="meta">背景：{{record.backgroundDisplay || record.backgroundColorLabel || record.backgroundColor || "--"}}</view>
    <view class="meta">时间：{{record.createdAt}}</view>

    <view wx:if="{{!manageMode}}" class="action-row">
      <view class="action-btn" catchtap="handleEdit">编辑</view>
      <view class="action-btn action-btn-danger" catchtap="handleDelete">删除</view>
    </view>
  </view>
</view>
