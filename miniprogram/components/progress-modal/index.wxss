.progress-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(15, 23, 42, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.progress-card {
  width: 100%;
  max-width: 620rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.title { font-size: 34rpx; color: #0f172a; font-weight: 600; }
.subtitle { margin-top: 8rpx; font-size: 24rpx; color: #64748b; }
.stage-block { margin-top: 20rpx; }
.stage-name { font-size: 28rpx; color: #1e293b; font-weight: 600; }
.stage-desc { margin-top: 8rpx; font-size: 24rpx; color: #475569; line-height: 1.6; }
.elapsed { margin-top: 8rpx; font-size: 22rpx; color: #94a3b8; }

.track {
  height: 12rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #e2e8f0;
}

.bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #38bdf8, #0ea5e9);
  transition: width 360ms ease;
}

.stage-list { margin-top: 20rpx; display: flex; flex-direction: column; gap: 12rpx; }
.stage-item { display: flex; align-items: center; color: #94a3b8; font-size: 22rpx; }
.stage-item .dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #cbd5e1;
}
.stage-item.is-done,
.stage-item.is-active { color: #1e293b; }
.stage-item.is-done .dot,
.stage-item.is-active .dot { background: #38bdf8; }

.action-row { margin-top: 22rpx; }
.retry-btn {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  background: #e0f2fe;
  color: #0369a1;
  font-size: 28rpx;
  border: none;
}
