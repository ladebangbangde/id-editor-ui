<view class="color-list">
  <view wx:for="{{options}}" wx:key="value" class="color-item {{item.value===value?'active':''}}" data-value="{{item.value}}" bindtap="handleTap">
    <view class="dot {{item.value==='white'?'dot-white':''}}" style="background: {{item.hex}}"></view>
    <text class="label">{{item.label}}</text>
  </view>
</view>
