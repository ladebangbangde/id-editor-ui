.scene-card {
  display: flex;
  gap: 14rpx;
  border: 1rpx solid #e8edf3;
  border-radius: 20rpx;
  padding: 16rpx;
  background: #fff;
}
.featured { border-color: #cad6ef; }
.icon {
  width: 74rpx;
  height: 74rpx;
  border-radius: 16rpx;
  background: #f2f4f8;
  color: #475569;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
.main { flex: 1; }
.row-between { display: flex; justify-content: space-between; align-items: center; }
.name { font-size: 28rpx; font-weight: 600; color: #111827; }
.tag { font-size: 20rpx; color: #4b5563; background: #eef2f7; border-radius: 8rpx; padding: 2rpx 8rpx; }
.desc { display:block; margin-top: 6rpx; font-size: 22rpx; color: #6b7280; }
