.size-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.size-item {
  min-width: 150rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
  text-align: center;
  border: 2rpx solid transparent;
}

.size-item.active {
  border-color: rgba(45, 107, 255, 0.55);
  background: rgba(45, 107, 255, 0.12);
  box-shadow: 0 8rpx 18rpx rgba(45, 107, 255, 0.12);
}

.size-name {
  font-size: 26rpx;
  color: #111827;
}
