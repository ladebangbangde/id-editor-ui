<view class="color-list">
  <block wx:for="{{options}}" wx:key="value">
    <view
      class="color-item {{item.value === value ? 'active' : ''}}"
      data-value="{{item.value}}"
      bindtap="handleTap"
    >
      <view class="dot {{item.value === 'white' ? 'white-dot' : ''}}" style="background: {{item.hex}}"></view>
      <text class="name">{{item.label}}</text>
    </view>
  </block>
</view>
